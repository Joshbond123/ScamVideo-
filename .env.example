# AI Studio automatically injects this at runtime from user secrets.
# You can still keep a local .env for development if you want.

# Supabase-backed state & storage (required)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_MEDIA_BUCKET="temp-media"

# Cloudflare Workers AI image generation
CLOUDFLARE_ACCOUNT_ID=""

# GitHub Actions + GStreamer render pipeline (required for video rendering)
GITHUB_PAT="YOUR_GITHUB_PAT"
GITHUB_RENDER_REPO="owner/repo"
GITHUB_RENDER_WORKFLOW="gstreamer-render.yml"
GITHUB_RENDER_REF="main"

# Optional
PORT=3000
